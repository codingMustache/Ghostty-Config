# Config generated by Ghostty Config
custom-shader = ~/.config/ghostty/shader.glsli


title = "👻"
shell-integration-features = true
confirm-close-surface = false
quit-after-last-window-closed = false
clipboard-read = allow
clipboard-write = allow
copy-on-select = true

# Window
background-opacity = 0.95
split-divider-color = #111111
background-blur = 18
window-padding-x = 0
window-padding-y = 5

# theme nord
background = #2e3440
foreground = #d8dee9
selection-background = #3f4758
selection-foreground = #d8dee9
cursor-color = #d8dee9
cursor-text = #2e3440
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4



# Font
font-size = 12
font-thicken = true
font-thicken-strength = 115
font-family = "FiraCode Nerd Font Mono"
adjust-cell-height = 3

bell-features = border

############### KeyMaps
keybind = ctrl+alt+right=new_split:right
keybind = ctrl+alt+left=new_split:left
keybind = ctrl+alt+up=new_split:up
keybind = ctrl+alt+down=new_split:down
keybind = ctrl+down=goto_split:down
keybind = ctrl+up=goto_split:up
keybind = ctrl+right=goto_split:right
keybind = ctrl+left=goto_split:left
keybind = ctrl+shift+r=reset

# Reload config
keybind = cmd+shift+r=reload_config
# quick terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal


# Quick terminal
quick-terminal-animation-duration = 0.17
quick-terminal-size = 35%,100%
quick-terminal-position = left
quick-terminal-space-behavior =remain
quick-terminal-autohide = false
quick-terminal-screen=macos-menu-bar


macos-option-as-alt = true
#macos-hidden = always
macos-secure-input-indication = false
auto-update = check
macos-icon = retro
macos-icon-frame = chrome
macos-icon-ghost-color = #3E8484
macos-icon-screen-color = #1B2626
